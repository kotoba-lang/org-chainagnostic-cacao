{:paths ["src" "test"]
 :deps {io.github.kotoba-lang/ed25519  {:local/root "../ed25519"}
        io.github.kotoba-lang/dag-cbor {:local/root "../dag-cbor"}}
 :tasks
 {test
  {:task (do (require 'clojure.test 'cacao.core-test)
